# ===========================================
# Smart Maize Farming System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ===========================================
# Convex Configuration
# ===========================================
CONVEX_URL=https://your-deployment.convex.cloud

# ===========================================
# Clerk Authentication
# ===========================================
CLERK_PUBLISHABLE_KEY=pk_test_your-key
CLERK_SECRET_KEY=sk_test_your-key
CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret
# Comma-separated emails allowed to bootstrap admin role on first login
ADMIN_BOOTSTRAP_EMAILS=

# ===========================================
# Cloudinary Configuration
# ===========================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_UPLOAD_PRESET=smart_maize_uploads

# ===========================================
# Africa's Talking (SMS/USSD)
# ===========================================
AT_USERNAME=sandbox
AT_API_KEY=your-africas-talking-api-key
AT_SHORTCODE=44005
AT_SENDER_ID=SMARTMAIZE

# ===========================================
# Weather API
# ===========================================
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
WEATHER_CACHE_TTL=1800

# ===========================================
# Redis Cache (Optional)
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# AI/ML Service Configuration
# ===========================================
# Google Gemini AI (Primary AI Provider)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=gemini

# Legacy AI Service (Optional fallback)
AI_SERVICE_URL=http://localhost:5000
AI_SERVICE_API_KEY=your-ai-service-key
PEST_DETECTION_THRESHOLD=0.75
IRRIGATION_MODEL_VERSION=v1.0

# ===========================================
# Security
# ===========================================
JWT_SECRET=your-super-secret-jwt-key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# IoT Device Authentication
# ===========================================
IOT_DEVICE_SECRET=your-iot-device-shared-secret
IOT_TOKEN_EXPIRY=86400

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=combined

# ===========================================
# Notification Settings
# ===========================================
CRITICAL_ALERT_DELAY_MS=0
IMPORTANT_RECOMMENDATION_DELAY_MS=300000
ROUTINE_UPDATE_BATCH_INTERVAL_MS=3600000
