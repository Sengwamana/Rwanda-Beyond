              "host": ["{{base_url}}"],
              "path": ["recommendations", "farm", "{{farm_id}}", "active"]
            }
          }
        },
        {
          "name": "Respond to Recommendation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"accept\",\n  \"reason\": \"Will implement today\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/recommendations/:recommendationId/respond",
              "host": ["{{base_url}}"],
              "path": ["recommendations", ":recommendationId", "respond"],
              "variable": [
                {
                  "key": "recommendationId",
                  "value": "{{recommendation_id}}"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Pest Detection",
      "item": [
        {
          "name": "Upload Pest Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "images",
                  "type": "file",
                  "description": "Pest image file"
                },
                {
                  "key": "notes",
                  "value": "Suspicious spots on leaves",
                  "type": "text"
                },
                {
                  "key": "severity",
                  "value": "medium",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/pest-detection/upload/{{farm_id}}",
              "host": ["{{base_url}}"],
              "path": ["pest-detection", "upload", "{{farm_id}}"]
