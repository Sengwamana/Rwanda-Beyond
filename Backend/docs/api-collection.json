    {
      "name": "Sensors",
      "item": [
        {
          "name": "List Farm Sensors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sensors/farm/{{farm_id}}",
              "host": ["{{base_url}}"],
              "path": ["sensors", "farm", "{{farm_id}}"]
            }
          }
        },
        {
          "name": "Get Sensor Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sensors/data/farm/{{farm_id}}?page=1&limit=50",
              "host": ["{{base_url}}"],
              "path": ["sensors", "data", "farm", "{{farm_id}}"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "50"}
              ]
            }
          }
        },
        {
          "name": "Get Latest Readings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sensors/data/farm/{{farm_id}}/latest",
              "host": ["{{base_url}}"],
              "path": ["sensors", "data", "farm", "{{farm_id}}", "latest"]
            }
          }
        },
        {
          "name": "Get Daily Aggregates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/sensors/data/farm/{{farm_id}}/aggregates?days=7",
              "host": ["{{base_url}}"],
              "path": ["sensors", "data", "farm", "{{farm_id}}", "aggregates"],
              "query": [
                {"key": "days", "value": "7"}
              ]
            }
          }
        },
        {
          "name": "IoT: Ingest Sensor Data",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Device-ID",
                "value": "{{device_id}}"
              },
              {
                "key": "X-Device-Token",
                "value": "{{device_token}}"
              },
              {
                "key": "X-Timestamp",
                "value": "{{$timestamp}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"readings\": [\n    {\n      \"sensorType\": \"soil_moisture\",\n      \"value\": 42.5,\n      \"unit\": \"percent\"\n    },\n    {\n      \"sensorType\": \"soil_temperature\",\n      \"value\": 24.3,\n      \"unit\": \"celsius\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/sensors/data/ingest",
              "host": ["{{base_url}}"],
              "path": ["sensors", "data", "ingest"]
            }
          }
        }
      ]
    },
    {
      "name": "Recommendations",
      "item": [
        {
          "name": "List Farm Recommendations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/recommendations/farm/{{farm_id}}?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["recommendations", "farm", "{{farm_id}}"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "20"}
              ]
