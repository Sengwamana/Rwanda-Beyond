        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api/v1"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "farm_id",
      "value": "00000000-0000-0000-0000-000000000001"
    },
    {
      "key": "sensor_id",
      "value": "00000000-0000-0000-0000-000000000001"
    },
    {
      "key": "device_id",
      "value": "demo_device_001"
    },
    {
      "key": "device_token",
      "value": ""
    }
  ],
  "item": [
