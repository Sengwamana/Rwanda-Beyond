    {
      "name": "Farms",
      "item": [
        {
          "name": "List My Farms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/farms",
              "host": ["{{base_url}}"],
              "path": ["farms"]
            }
          }
        },
        {
          "name": "Create Farm",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Maize Farm\",\n  \"district\": \"Rwamagana\",\n  \"sector\": \"Gishari\",\n  \"cell\": \"Rubona\",\n  \"village\": \"Nyarubuye\",\n  \"size_hectares\": 1.5,\n  \"location\": {\"lat\": -1.9403, \"lng\": 30.4389},\n  \"crop_type\": \"maize\",\n  \"planting_date\": \"2026-01-01\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/farms",
              "host": ["{{base_url}}"],
              "path": ["farms"]
            }
          }
        },
        {
          "name": "Get Farm Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/farms/{{farm_id}}",
              "host": ["{{base_url}}"],
              "path": ["farms", "{{farm_id}}"]
            }
          }
        },
        {
          "name": "Get Farm Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/farms/{{farm_id}}/summary",
              "host": ["{{base_url}}"],
              "path": ["farms", "{{farm_id}}", "summary"]
            }
          }
        },
        {
          "name": "Update Farm",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_growth_stage\": \"flowering\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/farms/{{farm_id}}",
              "host": ["{{base_url}}"],
              "path": ["farms", "{{farm_id}}"]
            }
