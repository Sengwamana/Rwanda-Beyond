          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"confirmedPest\": \"Fall Armyworm\",\n  \"confirmedSeverity\": \"high\",\n  \"status\": \"confirmed\",\n  \"expertNotes\": \"Confirmed FAW infestation, recommend immediate treatment\",\n  \"treatmentRecommendations\": [\"Apply recommended pesticide\", \"Monitor surrounding areas\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/pest-detection/:detectionId/review",
              "host": ["{{base_url}}"],
              "path": ["pest-detection", ":detectionId", "review"],
              "variable": [
                {
                  "key": "detectionId",
                  "value": "{{detection_id}}"
                }
              ]
            }
          }
        }
      ]
