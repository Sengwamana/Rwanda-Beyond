{
  "name": "smart-maize-farming-backend",
  "version": "1.0.0",
  "description": "IoT-Based Smart Maize Farming System Backend - AI-driven decision support for irrigation optimization and Fall Armyworm detection",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "eslint src/",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js"
  },
  "keywords": [
    "iot",
    "agriculture",
    "smart-farming",
    "maize",
    "irrigation",
    "pest-detection",
    "rwanda"
  ],
  "author": "Smart Maize Team",
  "license": "MIT",
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@google/generative-ai": "^0.21.0",
    "africastalking": "^0.7.8",
    "axios": "^1.6.0",
    "cloudinary": "^1.41.0",
    "compression": "^1.7.4",
    "convex": "^1.31.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
