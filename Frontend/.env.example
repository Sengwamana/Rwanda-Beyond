# ===========================================
# Smart Maize Farming System - Frontend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# API Configuration
# ===========================================
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=ws://localhost:3000/ws

# ===========================================
# Clerk Authentication
# ===========================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your-key

# ===========================================
# Feature Flags
# ===========================================
VITE_ENABLE_WEBSOCKET=true
VITE_ENABLE_VOICE_ASSISTANT=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_OFFLINE_MODE=false

# ===========================================
# Optional: Map Configuration
# ===========================================
VITE_MAPBOX_ACCESS_TOKEN=

# ===========================================
# Optional: Error Tracking
# ===========================================
VITE_SENTRY_DSN=

# ===========================================
# Cache Configuration (in seconds)
# ===========================================
VITE_SENSOR_CACHE_TTL=30
VITE_WEATHER_CACHE_TTL=300
VITE_FARM_CACHE_TTL=60

# ===========================================
# Debugging
# ===========================================
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info
